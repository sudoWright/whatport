# WhatPort build / release configuration. Copy to .env and fill in.
# .env is gitignored and never mirrored to the public repo.

# Developer ID Application identity for signing (see: security find-identity -v -p codesigning).
# Leave empty for ad-hoc signing (local runs only; Gatekeeper warns elsewhere).
DEVELOPER_ID="Developer ID Application: Your Name (TEAMID)"

# notarytool keychain profile name. A profile is reusable across apps from the
# same team, so an existing one works. Create with:
#   xcrun notarytool store-credentials "WhatPort-notary" \
#       --apple-id <id> --team-id <TEAMID> --password <app-specific-password>
# Leave empty to sign without notarising.
NOTARY_PROFILE=""

# Local clone of the homebrew-whatport tap, for the cask bump. Leave empty to skip.
TAP_DIR="$HOME/Projects/personal/homebrew-whatport"

# If "1", release.sh / bump-cask.sh push the tap automatically.
CASK_AUTOPUSH="0"
